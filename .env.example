# Spectrum (iMessage provider)
SPECTRUM_PROJECT_ID=your-project-id
SPECTRUM_PROJECT_SECRET=your-project-secret
SPECTRUM_WEBHOOK_SECRET=your-webhook-secret

# LLM Provider (Xiaomi Token Plan SGP)
LLM_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=mimo-v2.5

# Optional
WORKING_DIRECTORY=/path/to/your/code
LOG_DIR=./logs
DEBUG=1
